{
  "name": "sessionmanager",
  "version": "1.0.0",
  "description": "Terminal grid manager — see all your terminal sessions at a glance",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "dev:web": "cd web && npm run dev",
    "dev:all": "concurrently -n app,web -c cyan,magenta \"npm run dev\" \"npm run dev:web\"",
    "build": "electron-vite build && cp resources/tray-icon.png out/tray-icon.png",
    "preview": "electron-vite preview",
    "postinstall": "electron-rebuild -f -w node-pty",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^8.2.0",
    "node-pty": "^1.1.0",
    "uuid": "^9.0.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.21"
  },
  "build": {
    "appId": "com.sessionmanager.app",
    "productName": "SessionManager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "npmRebuild": true,
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": "AppImage"
    },
    "win": {
      "target": "nsis"
    }
  }
}
